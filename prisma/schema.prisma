// SQLite for zero-config local dev. For production, switch the provider to
// "postgresql" and point DATABASE_URL at Postgres (no enums/arrays are used,
// so the schema ports cleanly).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Deal {
  id          String   @id @default(cuid())
  codeName    String
  targetName  String?
  industry    String
  description String
  geography   String?
  revenueBand String?
  ebitdaBand  String?
  evBand      String?

  // Generated by the pipeline (Claude):
  buyerThesis    String? // narrative rationale for who would buy this
  searchCriteria String? // JSON: { keywords, industries, employeeMin, ... }

  status    String   @default("draft") // draft | generating | ready
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries ListEntry[]
}

model Buyer {
  id          String   @id @default(cuid())
  name        String
  type        String // strategic | sponsor
  industry    String?
  size        String? // e.g. "500-1000 employees" or "$2B fund"
  location    String?
  website     String?
  description String?
  signals     String? // JSON: M&A appetite signals
  source      String? // apollo | clay | pitchbook | mock
  createdAt   DateTime @default(now())

  entries  ListEntry[]
  contacts Contact[]
}

model Contact {
  id      String  @id @default(cuid())
  buyerId String
  buyer   Buyer   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  name    String
  title   String?
  role    String? // corp dev | deal partner | ...
  email   String?
  phone   String?
}

model ListEntry {
  id        String  @id @default(cuid())
  dealId    String
  buyerId   String
  deal      Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  buyer     Buyer   @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  score     Int
  tier      String // A | B | C
  status    String  @default("pending") // pending | accepted | rejected
  rationale String?
  notes     String?
  dimensions String? // JSON: per-dimension score breakdown
  createdAt DateTime @default(now())
}
