# Copy to .env:  cp .env.example .env
# The app RUNS WITHOUT KEYS — it falls back to realistic mock data so you can
# demo the full flow. Add keys to switch each integration to live data.

# --- Required ---
DATABASE_URL=               # Postgres, e.g. postgresql://user:pass@host:5432/buyers_list (Neon/Vercel/Supabase/local)

# --- Live data (optional; mock used when absent) ---
ANTHROPIC_API_KEY=          # Claude: search-criteria + fit rationale (model: claude-opus-4-8)
APOLLO_API_KEY=             # Apollo.io: company + people search / enrichment
EXA_API_KEY=                # Exa.ai: neural web search to discover real acquirers / PE firms
CLAY_WEBHOOK_URL=           # Clay: waterfall enrichment table (inbound webhook)
CLAY_API_KEY=               # Clay: API key if pulling results back

# --- Optional data sources (phase in later) ---
PITCHBOOK_API_KEY=          # PE firms, funds, deal comps
GRATA_API_KEY=              # Private-company / strategics discovery
CRUNCHBASE_API_KEY=         # Supplemental company data

# --- Optional delivery / outreach ---
GOOGLE_CLIENT_ID=           # Google Drive export
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
CRM_API_KEY=                # DealCloud / Affinity / Salesforce (system of record TBD)
CRM_BASE_URL=
